{
  "name": "team-ai-monorepo",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "dev:web": "pnpm --filter web dev",
    "dev:api": "pnpm --filter @team-ai/api dev",
    "build:web": "pnpm --filter web build",
    "build:api": "pnpm --filter @team-ai/api build",
    "lint": "turbo run lint",
    "test:types": "pnpm --filter @team-ai/types test",
    "format": "prettier --write \"**/*.{ts,tsx,md}\""
  },
  "devDependencies": {
    "turbo": "latest",
    "prettier": "^3.0.0"
  },
  "packageManager": "pnpm@9.0.0"
}
